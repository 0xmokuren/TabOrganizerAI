{
  "manifest_version": 3,
  "name": "AI Tab Organizer",
  "version": "1.0.6",
  "description": "Chrome のローカル AI（Gemini Nano）でタブを自動グループ化します",
  "permissions": ["tabs", "tabGroups", "storage"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Tab Organizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
